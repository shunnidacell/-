# Comma-separated ccxt exchange ids. Start with public market data only.
EXCHANGES=binance,okx,bitget

# Trading pairs to monitor.
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT

# Quote currency amount used when auto-optimization is disabled.
TRADE_SIZE_QUOTE=100

# Upper bound used by the web dashboard when auto-optimizing trade size.
MAX_OPTIMIZED_TRADE_QUOTE=1000

# Minimum net profit percentage after fees and slippage.
MIN_NET_PROFIT_PCT=0.20

# Per-side estimated taker fee percentage if exchange-specific fees are unknown.
DEFAULT_TAKER_FEE_PCT=0.10

# Per-side estimated slippage percentage.
SLIPPAGE_PCT=0.03

# Poll interval in seconds.
POLL_SECONDS=5

# Order book depth used for weighted executable prices.
ORDERBOOK_LIMIT=10

# demo or live. Keep demo until you have tested with small size.
MODE=demo

# Safety switch. Keep false until you add private API credentials.
LIVE_TRADING=false

# Required for live mode.
LIVE_CONFIRM=

# Extra live risk cap. The web app will not place one arbitrage leg above this quote amount.
MAX_LIVE_TRADE_QUOTE=25

# Example private API credentials. Use exchange ids from EXCHANGES.
BINANCE_API_KEY=
BINANCE_SECRET=
OKX_API_KEY=
OKX_SECRET=
OKX_PASSWORD=
BITGET_API_KEY=
BITGET_SECRET=
BITGET_PASSWORD=
